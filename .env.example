# Copy to .env and fill in. .env is gitignored.

# DeepSeek API key — current default summarizer (SUMMARIZER_PROVIDER=deepseek).
# Create at https://platform.deepseek.com -> API keys (top up a small balance).
DEEPSEEK_API_KEY=

# GitHub Personal Access Token with `models:read` scope.
# Only needed if SUMMARIZER_PROVIDER=github_models.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Anthropic API key (only needed if SUMMARIZER_PROVIDER=claude).
ANTHROPIC_API_KEY=

# Bark device key (only needed once M3 lands).
BARK_KEY=
