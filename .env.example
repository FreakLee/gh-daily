# Copy to .env and fill in. .env is gitignored.

# GitHub Personal Access Token with `models:read` scope.
# Needed for the GitHub Models summarizer.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Anthropic API key (only needed if SUMMARIZER_PROVIDER=claude).
ANTHROPIC_API_KEY=

# Bark device key (only needed once M3 lands).
BARK_KEY=
